{{#> layout}}
{{#*inline "head"}}
<title>{{displayedUser.name}} - {{@websiteName}}</title>
<style>
.result-correct {
    background-color: #009900;
}
.result-diff {
    background-color: #00e600;
}
.result-winner {
    background-color: #ccffcc;
}

.extra-bet-correct {
    display: inline-block;
    padding: 3px;
    background-color: #009900;
    color: white;
    border-radius: 3px;
}

.extra-bet-wrong {
    display: inline-block;
    padding: 3px;
    background-color: #eee;
    border-radius: 3px;
}
</style>
{{/inline}}
{{#*inline "body"}}
{{> navbar}}
<div class="container">

<h3>{{displayedUser.name}} <small class="text-muted">{{ @tr "user.summary" score=displayedUser.score rank=displayedUser.rank }}</small></h3>

{{#if extraBets}}
    <div class="row row-cols-1 row-cols-lg-3 g-3 mt-3">
        {{#each extraBets}}
        <div class="col">
            <div class="card h-100">
                <div class="card-header">
                    {{name}} ({{ @tr "user.extra_bet_summary" correct=numberOfCorrectTeams factor=scoreFactor total=totalScore }})
                </div>
                <div class="card-body">
                    {{#each teams}}
                        <div {{#if isCorrect}}class="extra-bet-correct"{{else}}class="extra-bet-wrong"{{/if}}>{{#if code}}<img class="flag-icon me-1" src="{{flagUrl code}}" alt="{{name}} flag" loading="lazy">{{/if}}{{name}}</div>
                    {{else}}
                        <span class="text-muted small">{{ @t "user.no_teams_selected" }}</span>
                    {{/each}}
                </div>
            </div>
        </div>
        {{/each}}
    </div>
{{/if}}


{{#if matchesPerDayList}}
<table class="table table-sm mt-3">
    <thead class="table-light">
    <tr>
        <th colspan="2"></th>
        <th colspan="3" class="text-center">{{ @t "user.match_result_column" }}</th>
        <th class="text-center">{{ @t "user.bet_column" }}</th>
        <th class="text-center">{{ @t "user.points_column" }}</th>
    </tr>
    </thead>
    <tbody>
    {{#each matchesPerDayList}}
        <tr>
            <td colspan="7" class="pt-4">
                {{formatDate date}}
            </td>
        </tr>
        {{#each matches}}
        <tr class="result-{{result}}">
            <td class="small"><span class="d-none d-sm-inline">{{formatTime starts_at}}</span><span class="d-sm-none">{{formatTime starts_at}}</span></td>
            <td class="small">
                <span class="d-none d-sm-inline">{{match_type_name}}</span>
                <span class="d-sm-none">{{match_type_code}}</span>
                {{> score_factor match_type_score_factor}}
            </td>
            <td class="text-end">
                <em class="d-none d-sm-inline">
                    {{home_team_name}}
                    {{#if home_team_code}}<img class="flag-icon ms-1" src="{{flagUrl home_team_code}}" alt="{{home_team_name}} flag" loading="lazy">{{/if}}
                </em>
                <em class="d-sm-none">
                    {{home_team_code}}
                    {{#if home_team_code}}<img class="flag-icon ms-1" src="{{flagUrl home_team_code}}" alt="{{home_team_name}} flag" loading="lazy">{{/if}}
                </em>
            </td>
            <td class="text-center">
                <strong>{{showGoals match_goals_home}}</strong> : <strong>{{showGoals match_goals_away}}</strong>
            </td>
            <td class="text-start">
                <em class="d-none d-sm-inline">
                    {{#if away_team_code}}<img class="flag-icon me-1" src="{{flagUrl away_team_code}}" alt="{{away_team_name}} flag" loading="lazy">{{/if}}
                    {{away_team_name}}
                </em>
                <em class="d-sm-none">
                    {{#if away_team_code}}<img class="flag-icon me-1" src="{{flagUrl away_team_code}}" alt="{{away_team_name}} flag" loading="lazy">{{/if}}
                    {{away_team_code}}
                </em>
            </td>
            <td class="text-center">
            {{showGoals bet_goals_home}} : {{showGoals bet_goals_away}}
            </td>
            <td class="text-center {{#if (isZero score)}}is-zero{{/if}}">
            {{score}}
            </td>
        </tr>
        {{/each}}
    {{/each}}
    </tbody>
</table>
{{else}}
<div class="alert alert-danger" role="alert">
    <strong>{{ @t "user.empty_state" }}</strong>
</div>
{{/if}}
</div>
{{/inline}}
{{/layout}}

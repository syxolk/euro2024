{{#> layout}}
{{#*inline "head"}}
<title>{{ @t "past.title" }} - {{@websiteName}}</title>
<style>
    .highlight-friend {
        background-color: #F8DE7E;
        padding: 3px 5px;
        display:inline-block;
        border-radius: 3px;
    }
    [data-bs-theme=dark] .highlight-friend {
        background-color: transparent;
        border: 1px solid #F8DE7E;
    }

    .highlight-me {
        background-color: #ffd700;
        padding: 3px 5px;
        display:inline-block;
        border-radius: 3px;
    }
    [data-bs-theme=dark] .highlight-me {
        background-color: transparent;
        border: 1px solid #ffd700;
    }
</style>
{{/inline}}
{{#*inline "body"}}
{{> navbar}}
<div class="container">

{{#if is_logged_in}}
    <div class="mb-3">
        {{#if order_by_gain}}
            <a href="/past">{{ @t "past.order_by_date" }}</a>
        {{else}}
            <a href="/past?gain=1">{{ @t "past.order_by_gain" }}</a>
        {{/if}}
    </div>
{{/if}}

{{#if matches}}
<div id="accordion" role="tablist">
{{#each matches}}
<div class="card mb-2"
    {{#if unseen}}
        {{#if (gt goalshome goalsaway)}}data-confetti="true" data-confetti-winner-side="home"{{#if home_team_code}} data-confetti-team-code="{{home_team_code}}"{{/if}}{{/if}}
        {{#if (lt goalshome goalsaway)}}data-confetti="true" data-confetti-winner-side="away"{{#if away_team_code}} data-confetti-team-code="{{away_team_code}}"{{/if}}{{/if}}
    {{/if}}>
    <div class="card-header">
        <div class="row g-2 align-items-start">
            <div class="col">
                <a role="button" data-bs-toggle="collapse" href="#match-{{id}}" aria-expanded="false" aria-controls="match-{{id}}">
                    {{#if home_team_code}}<img class="flag-icon me-1" src="{{flagUrl home_team_code}}" alt="{{hometeam}} flag" loading="lazy">{{/if}}{{~hometeam}} <b>{{goalshome}}</b> : <b>{{goalsaway}}</b> {{#if away_team_code}}<img class="flag-icon mx-1" src="{{flagUrl away_team_code}}" alt="{{awayteam}} flag" loading="lazy">{{/if}}{{awayteam~}}
                </a>
                ({{matchtype}}) {{> score_factor score_factor }}
                <br/>
                <small class="text-muted">{{ @tr "format.date_time" value=starts_at }}{{#if goals_inserted_at}} / {{ @tr "format.date_time" value=goals_inserted_at }}{{/if}}</small>
            </div>
            {{#if @root.is_logged_in}}
                <div class="col-12 col-md-4 text-md-end text-start">
                    {{ @t "past.gain_label" }} {{my_gain}}
                    <br/>
                    <small class="text-muted">
                        {{ @t "past.my_score_label" }} {{my_score}},
                        {{ @t "past.avg_friend_score_label" }} {{avg_friend_score}}
                    </small>
                </div>
            {{/if}}
        </div>
    </div>
    <div id="match-{{id}}" class="collapse {{#if unseen}}show{{/if}}" role="tabpanel">
        <div class="card-body">
            <div class="progress">
                <div class="progress-bar bg-dark" role="progressbar" style="width: {{percent.home}}%;">
                    {{percent.home}}% {{hometeam}}
                </div>
                <div class="progress-bar text-dark" role="progressbar" style="width: {{percent.draw}}%;background-color:#ccc;">
                    {{percent.draw}}% {{ @t "past.draw_label" }}
                </div>
                <div class="progress-bar bg-secondary" role="progressbar" style="width: {{percent.away}}%;">
                    {{percent.away}}% {{awayteam}}
                </div>
            </div>
        </div>
        <ul class="list-group list-group-flush">
            {{#if bets.correct}}
            <li class="list-group-item">
                <div class="row">
                    <div class="col-md-2">{{> correct_bet}}</div>
                    <div class="col-md-10">
                        {{#each bets.correct}}
                            {{#if @first}}{{else}},{{/if}}
                            <span {{#if is_friend}}class="highlight-friend"{{/if}}{{#if is_me}}class="highlight-me"{{/if}}>
                                <a href="/user/{{id}}">{{name}}</a>
                            </span>
                        {{/each}}
                    </div>
                </div>
            </li>
            {{/if}}
            {{#if bets.diff}}
            <li class="list-group-item">
                <div class="row">
                    <div class="col-md-2">{{> correct_diff}}</div>
                    <div class="col-md-10">
                        {{#each bets.diff}}
                            {{#if @first}}{{else}},{{/if}}
                            <span {{#if is_friend}}class="highlight-friend"{{/if}}{{#if is_me}}class="highlight-me"{{/if}}>
                                <a href="/user/{{id}}">{{name}}</a>
                                {{#if is_friend}}<b>{{/if}}{{goals_home}}:{{goals_away}}{{#if is_friend}}</b>{{/if}}
                            </span>
                        {{/each}}
                    </div>
                </div>
            </li>
            {{/if}}
            {{#if bets.winner}}
            <li class="list-group-item">
                <div class="row">
                    <div class="col-md-2">{{> correct_winner}}</div>
                    <div class="col-md-10">
                        {{#each bets.winner}}
                            {{#if @first}}{{else}},{{/if}}
                            <span {{#if is_friend}}class="highlight-friend"{{/if}}{{#if is_me}}class="highlight-me"{{/if}}>
                                <a href="/user/{{id}}">{{name}}</a>
                                {{#if is_friend}}<b>{{/if}}{{goals_home}}:{{goals_away}}{{#if is_friend}}</b>{{/if}}
                            </span>
                        {{/each}}
                    </div>
                </div>
            </li>
            {{/if}}
            {{#if bets.wrong}}
            <li class="list-group-item">
                <div class="row">
                    <div class="col-md-2">{{> wrong_bet}}</div>
                    <div class="col-md-10">
                        {{#each bets.wrong}}
                            {{#if @first}}{{else}},{{/if}}
                            <span {{#if is_friend}}class="highlight-friend"{{/if}}{{#if is_me}}class="highlight-me"{{/if}}>
                                <a href="/user/{{id}}">{{name}}</a>
                                {{#if is_friend}}<b>{{/if}}{{goals_home}}:{{goals_away}}{{#if is_friend}}</b>{{/if}}
                            </span>
                        {{/each}}
                    </div>
                </div>
            </li>
            {{/if}}
        </ul>
    </div>
</div>
{{/each}}
</div>
{{else}}
<div class="alert alert-danger" role="alert">
    <strong>{{ @t "past.empty_state" }}</strong>
</div>
{{/if}}
</div>
{{/inline}}
{{/layout}}

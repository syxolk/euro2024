{{#> layout}}
{{#*inline "head"}}
<title>{{matchType.name}} - {{@websiteName}}</title>
<style>
    .highlight-friend {
        background-color: #F8DE7E;
        padding: 3px 5px;
        display:inline-block;
        border-radius: 3px;
    }
    [data-bs-theme=dark] .highlight-friend {
        background-color: transparent;
        border: 1px solid #F8DE7E;
    }

    .highlight-me {
        background-color: #ffd700;
        padding: 3px 5px;
        display:inline-block;
        border-radius: 3px;
    }
    [data-bs-theme=dark] .highlight-me {
        background-color: transparent;
        border: 1px solid #ffd700;
    }

    .autosave {
        --autosave-success-bg: rgba(25, 135, 84, 0.25);
        --autosave-error-bg: rgba(220, 53, 69, 0.25);
    }

    [data-bs-theme=dark] .autosave {
        --autosave-success-bg: rgba(25, 135, 84, 0.45);
        --autosave-error-bg: rgba(220, 53, 69, 0.45);
    }

    @keyframes pulse-success {
        0%, 100% { background-color: transparent; }
        30% { background-color: var(--autosave-success-bg); }
    }

    .autosave-success {
        animation: pulse-success 1s;
    }

    @keyframes pulse-error {
        0%, 100% { background-color: transparent; }
        30% { background-color: var(--autosave-error-bg); }
    }

    .autosave-error {
        animation: pulse-error 1s;
    }
</style>
{{/inline}}
{{#*inline "body"}}
{{> navbar}}
<input type="hidden" name="_csrf" value="{{csrfToken}}">
<input type="hidden" name="_action" value="/save_bet">
<div class="container">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3">
        <div>
            <h2 class="mb-1">{{matchType.name}}</h2>
            {{#if (gt matchType.scoreFactor 1) }}
            <div class="text-muted">{{ @t "match_type_page.score_factor_label" }} {{> score_factor matchType.scoreFactor }}</div>
            {{/if}}
        </div>
    </div>

    {{#if matches}}
        {{#each matches}}
        <div class="card mb-3">
            <div class="card-header">
                <a data-bs-toggle="collapse" href="#match-{{id}}">
                    <strong>
                        {{#if home_team_name}}
                            {{home_team_name}}{{#if home_team_code}}<img class="flag-icon ms-1" src="{{flagUrl home_team_code}}" alt="{{home_team_name}} flag" loading="lazy">{{/if}}
                        {{else}}
                            {{placeholder_home}}
                        {{/if}}
                    </strong>
                    {{#if (or (eq goals_home 0) goals_home)}}
                        <strong>{{goals_home}}</strong> : <strong>{{goals_away}}</strong>
                    {{else}}
                        <strong>vs</strong>
                    {{/if}}
                    <strong>
                        {{#if away_team_name}}
                            {{#if away_team_code}}<img class="flag-icon me-1" src="{{flagUrl away_team_code}}" alt="{{away_team_name}} flag" loading="lazy">{{/if}}{{away_team_name}}
                        {{else}}
                            {{placeholder_away}}
                        {{/if}}
                    </strong>
                </a>
                <div class="text-muted small">
                    {{ @tr "format.date_time" value=starts_at }}
                    {{#if tv}}<span class="badge bg-secondary ms-1">{{tv}}</span>{{/if}}
                </div>
            </div>

            <div id="match-{{id}}" class="collapse {{#if (not is_started)}}show{{/if}}">
                {{#if is_started}}
                <div class="card-body pb-2">
                    <div class="small text-muted mb-2">{{ @tr "match_type_page.number_of_bets" count=all_bets.length }}</div>
                    {{#if all_bets.length}}
                    {{#if bet_groups}}
                        {{#each bet_groups}}
                        <div class="row mb-3">
                            <div class="col-md-2 text-muted fw-semibold">
                                {{#if (eq result "correct")}}{{> correct_bet}}{{/if}}
                                {{#if (eq result "diff")}}{{> correct_diff}}{{/if}}
                                {{#if (eq result "winner")}}{{> correct_winner}}{{/if}}
                                {{#if (eq result "wrong")}}{{> wrong_bet}}{{/if}}
                            </div>
                            <div class="col-md-10">
                                {{#each bets}}
                                    <span {{#if is_friend}}class="highlight-friend"{{/if}}{{#if is_me}}class="highlight-me"{{/if}}>
                                        <a href="/user/{{id}}">{{name}}</a>
                                        {{goals_home}}:{{goals_away}}
                                    </span>
                                {{/each}}
                            </div>
                        </div>
                        {{/each}}
                    {{else}}
                        {{#each all_bets}}
                            <span {{#if is_friend}}class="highlight-friend"{{/if}}{{#if is_me}}class="highlight-me"{{/if}}>
                                <a href="/user/{{id}}">{{name}}</a>
                                {{goals_home}}:{{goals_away}}
                            </span>
                        {{/each}}
                    {{/if}}
                    {{else}}
                    <div class="alert alert-secondary mb-0" role="alert">
                        {{ @t "match_type_page.no_bets" }}
                    </div>
                    {{/if}}
                </div>
                {{else}}
                <div class="card-body pb-2">
                    {{#if @root.user}}
                    <div class="row autosave g-2 mb-3 align-items-center">
                        <div class="col-auto text-center m-auto m-md-0">
                            <input type="number" min="0" max="20" autocomplete="off"
                                {{#if (not has_teams)}}disabled{{/if}}
                                class="form-control text-center"
                                style="display:inline;width:80px;" name="home" value="{{my_bet_goals_home}}">
                            <input type="hidden" name="match" value="{{id}}">
                            :
                            <input type="number" min="0" max="20" autocomplete="off"
                                {{#if (not has_teams)}}disabled{{/if}}
                                class="form-control text-center"
                                style="display:inline;width:80px;" name="away" value="{{my_bet_goals_away}}">
                        </div>
                    </div>
                    {{/if}}
                    <div class="alert alert-secondary mb-0" role="alert">
                        {{ @t "match_type_page.bets_hidden_until_start" }}
                    </div>
                </div>
                {{/if}}
            </div>
        </div>
        {{/each}}
    {{else}}
    <div class="alert alert-danger" role="alert">
        <strong>{{ @t "match_type_page.empty_state" }}</strong>
    </div>
    {{/if}}
</div>
{{/inline}}
{{/layout}}
<nav class="navbar navbar-dark navbar-expand-lg bg-dark fixed-top">
    <div class="container">
        <a class="navbar-brand" href="/intro">{{@websiteName}}</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div id="navbarSupportedContent" class="navbar-collapse collapse">
            <ul class="navbar-nav w-100">
                {{#if loggedIn}}
                <li class="nav-item"><a class="nav-link" href="/me">
                    {{ t "navbar.profile" }}
                </a></li>
                <li class="nav-item"><a class="nav-link" href="/mybets">
                    {{ t "navbar.my_bets" }}
                    {{#if (gt upcomingMatchesWithoutBet 0)}}<span class="badge bg-warning text-dark">{{ upcomingMatchesWithoutBet }}</span>{{/if}}
                </a></li>
                {{/if}}
                <li class="nav-item"><a class="nav-link" href="/live">
                    {{ t "navbar.live_matches" }}
                    {{#if hasLiveMatches}}<span class="badge bg-success">NOW</span>{{/if}}
                </a></li>
                <li class="nav-item"><a class="nav-link" href="/past">
                    {{ t "navbar.past_matches" }}
                    {{#if (gt unseenPastMatches 0)}}<span class="badge bg-warning text-dark">{{unseenPastMatches}}</span>{{/if}}
                </a></li>
                <li class="nav-item"><a class="nav-link" href="/highscore">
                    {{ t "navbar.highscore" }}
                </a></li>
                <li class="nav-item"><a class="nav-link" href="/extra_bet_list">
                    Extra Bets
                </a></li>
                {{#if loggedIn}}
                <li class="nav-item ms-lg-auto dropdown">
                    <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">{{user.name}}</a>
                    <div class="dropdown-menu dropdown-menu-end">
                        {{#if user.admin}}<a class="dropdown-item" href="/admin">Admin</a>{{/if}}
                        <a class="dropdown-item" href="/settings">
                            {{ t "navbar.settings" }}
                        </a>
                        <div class="dropdown-divider"></div>
                        <form method="post" action="/logout">
                            <input type="hidden" name="_csrf" value="{{csrfToken}}">
                            <button type="submit" class="btn btn-link dropdown-item">
                                {{ t "navbar.logout" }}
                            </button>
                        </form>
                    </div>
                </li>
                {{else}}
                <li class="nav-item ms-lg-auto"><a class="nav-link" href="/register">
                    {{ t "navbar.register" }}
                </a></li>
                <li class="nav-item"><a class="nav-link" href="/login">
                    {{ t "navbar.login" }}
                </a></li>
                {{/if}}
            </ul>
        </div>
    </div>
</nav>

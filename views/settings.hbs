{{#> layout}}
{{#*inline "head"}}
<title>{{ @t "settings.title" }} - {{@websiteName}}</title>
{{/inline}}
{{#*inline "body"}}
{{> navbar}}
<div class="container">

{{#if error}}
<div class="alert alert-danger" role="alert">
    {{error}}
</div>
{{/if}}

<form method="post" action="/settings">
    <input type="hidden" name="_csrf" value="{{csrfToken}}">
    <div class="mb-3">
        <label for="name">
            {{ @t "settings.name" }}
        </label>
        <input type="text" minlength="3" maxlength="30" required name="name" class="form-control" id="name" value="{{user.name}}">
    </div>
    <button type="submit" class="btn btn-primary">
        {{ @t "settings.submit_button" }}
    </button>
</form>

<hr/>

{{#if inviteCode}}
<h3>{{ @t "settings.invite_heading" }}</h3>
<p>{{ @t "settings.invite_info" }}</p>
<div class="input-group mb-2">
    <input type="text" class="form-control" id="inviteLinkInput" value="{{inviteLink}}" readonly>
    <button class="btn btn-outline-secondary" type="button" id="copyInviteLinkBtn">
        {{ @t "settings.invite_copy" }}
    </button>
</div>
<p class="text-muted">{{ @t "settings.invite_code_label" }}: <strong>{{inviteCode}}</strong></p>
<hr/>
{{/if}}

{{#if enabledGoogle}}
{{#if user.googleId}}
<div class="alert alert-success">
<strong>{{ @t "settings.google_connected" }}</strong>
<form method="post" action="/disconnect/google">
    <input type="hidden" name="_csrf" value="{{csrfToken}}">
    <button type="submit" class="btn btn-outline-danger btn-sm mt-3">{{ @t "settings.disconnect_google" }}</button>
</form>
</div>
{{else}}
<div class="alert alert-info">
<a class="btn btn-primary" href="/connect/google">{{ @t "settings.connect_google" }}</a>
<strong>{{ @t "settings.google_login_prompt" }}</strong>
{{ @t "settings.social_profile_id_notice" }}
</div>
{{/if}}
{{else}}
<div class="small text-muted">
    {{ @t "settings.google_disabled" }}
</div>
{{/if}}

</div>
{{/inline}}
{{/layout}}

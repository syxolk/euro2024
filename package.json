{
  "name": "worldcup2026",
  "description": "Worldcup 2026: Betting with your friends",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/syxolk/euro2016"
  },
  "scripts": {
    "prestart": "npm run build:frontend",
    "start": "tsx watch index.ts",
    "build:frontend": "tsx build_frontend.ts",
    "build:frontend:watch": "tsx build_frontend.ts --watch",
    "typecheck": "tsc --noEmit",
    "migrate:latest": "tsx ./node_modules/knex/bin/cli.js --knexfile knexfile.ts migrate:latest",
    "migrate:rollback": "tsx ./node_modules/knex/bin/cli.js --knexfile knexfile.ts migrate:rollback",
    "migrate:make": "tsx ./node_modules/knex/bin/cli.js --knexfile knexfile.ts migrate:make",
    "migrate:list": "tsx ./node_modules/knex/bin/cli.js --knexfile knexfile.ts migrate:list",
    "pretty": "prettier --write './**/*.{js,ts,tsx,css,scss}'",
    "check-pretty": "prettier --check './**/*.{js,ts,tsx,css,scss}'",
    "lint": "eslint routes frontend app.ts index.ts hbs_helpers.ts db.ts config.ts build_frontend.ts",
    "test": "NODE_ENV=test vitest run",
    "test:watch": "NODE_ENV=test vitest",
    "test:setup": "docker compose -f docker-compose.test.yml up -d",
    "test:teardown": "docker compose -f docker-compose.test.yml down"
  },
  "dependencies": {
    "@tsparticles/confetti": "^4.0.5",
    "axios": "^1.18.0",
    "bcrypt": "^6.0.0",
    "bootstrap": "^5.3.8",
    "chart.js": "^4.5.1",
    "compression": "^1.8.1",
    "connect-session-knex": "4.0.0",
    "csrf-sync": "^4.2.1",
    "datatables.net": "^2.3.8",
    "datatables.net-bs5": "^2.3.8",
    "express": "^5.2.1",
    "express-session": "^1.18.2",
    "hbs": "^4.2.1",
    "helmet": "^4.6.0",
    "i18next": "^23.11.5",
    "i18next-http-middleware": "^3.9.3",
    "knex": "^3.1.0",
    "morgan": "^1.10.1",
    "ms": "^2.1.3",
    "mustache": "^4.2.0",
    "node-mailjet": "^6.0.8",
    "nodemailer": "^9.0.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "pg": "^8.11.5",
    "prettier": "^3.8.4",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.19.0",
    "@types/hbs": "^4.0.5",
    "@types/morgan": "^1.9.10",
    "@types/ms": "^2.1.0",
    "@types/mustache": "^4.2.6",
    "@types/node": "^24.13.2",
    "@types/nodemailer": "^8.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^7.2.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "supertest": "^7.2.2",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.7"
  }
}
